# Copy this file to backend/.env and fill in your key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides:
# ORCHESTRATOR_MODEL=claude-opus-4-8      # reasoning engine (default). Use claude-sonnet-5 to cut cost.
# RETRIEVAL_MODEL=claude-sonnet-5         # cheap/fast leg: the retrieval subagent (retrieval.py).
# PAEDSCALE_MAX_TOKENS=4000
# RETRIEVAL_MAX_TOKENS=2500

# Live-retrieval keys (both endpoints work WITHOUT a key; a key only raises rate limits):
# OPENFDA_API_KEY=...                     # https://open.fda.gov/apis/authentication/
# NCBI_API_KEY=...                        # https://www.ncbi.nlm.nih.gov/account/  (PubMed E-utilities)
# NCBI_EMAIL=you@example.com              # polite identifier for NCBI E-utilities

# Shared drug-PK cache (in-process LRU — sized for a single Render dyno):
# PK_CACHE_MAX_ENTRIES=80
# PK_CACHE_MAX_BYTES=2000000              # ~2 MB total payload budget
# PK_CACHE_TTL_SECONDS=86400              # 24h
